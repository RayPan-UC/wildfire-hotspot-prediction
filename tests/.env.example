# FIRMS Map Key — get yours at https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Limit: 5000 transactions / 10 minutes (larger requests count as multiple)
FIRMS_API_KEY=your_firms_map_key_here

# Copernicus CDS Personal Access Token — get yours at https://cds.climate.copernicus.eu/profile
# Required for ERA5-Land weather data download
CDS_KEY=your_cds_personal_access_token_here

# NASA Earthdata Bearer Token — get yours at https://urs.earthdata.nasa.gov/profile
# Required for VIIRS cloud mask download (optional — cloud masking disabled if not set)
EARTHDATA_TOKEN=your_earthdata_bearer_token_here
